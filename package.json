{
  "name": "nodex",
  "version": "0.1.0",
  "description": "Cloud knowledge management in Chrome Side Panel",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "dev:test": "vite --config vite.config.standalone.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "check:test-sync": "node scripts/check-test-sync.mjs",
    "check:i18n-copy": "node scripts/check-component-copy.mjs",
    "verify": "npm run typecheck && npm run check:test-sync && npm run test:run && npm run build",
    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@leeoniya/ufuzzy": "^1.0.19",
    "@radix-ui/react-tooltip": "^1.2.8",
    "cmdk": "^1.1.1",
    "defuddle": "^0.6.6",
    "immer": "^10.1.1",
    "loro-crdt": "^1.10.6",
    "lucide-react": "^0.575.0",
    "nanoid": "^5.1.6",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "vite-plugin-wasm": "^3.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "^0.0.304",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.3",
    "@wxt-dev/module-react": "^1.1.2",
    "jsdom": "^24.1.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wxt": "^0.20.5"
  }
}
